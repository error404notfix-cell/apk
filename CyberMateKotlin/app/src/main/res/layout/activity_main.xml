<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CYBERMATE"
                    android:textColor="@color/neon_purple"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TELEGRAM BOT CONTROLLER"
                    android:textColor="@color/text_grey"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● OFFLINE"
                android:textColor="@color/neon_red"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/badge_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- BOT CONTROL CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BOT CONTROL"
                    android:textColor="@color/neon_cyan"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etToken"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Bot Token (BotFather se)"
                    android:hintTextColor="@color/text_dim"
                    android:textColor="@color/text_white"
                    android:textSize="13sp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textPassword"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"/>

                <EditText
                    android:id="@+id/etChatId"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Chat ID (@userinfobot se)"
                    android:hintTextColor="@color/text_dim"
                    android:textColor="@color/text_white"
                    android:textSize="13sp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="number"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="monospace"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnStart"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="▶ START BOT"
                        android:textColor="@color/bg_dark"
                        android:backgroundTint="@color/neon_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <Button
                        android:id="@+id/btnStop"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="■ STOP BOT"
                        android:textColor="@color/neon_red"
                        android:backgroundTint="@color/card_bg2"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:enabled="false"
                        android:alpha="0.5"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- LAST LOG -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAST ACTIVITY"
                    android:textColor="@color/neon_cyan"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvLastLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bot offline..."
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- QUICK SEND -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUICK SEND"
                    android:textColor="@color/neon_pink"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="12dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:rowCount="2"
                    android:useDefaultMargins="true">

                    <Button android:id="@+id/btnSendStatus"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:text="/status" android:textSize="10sp"
                        android:backgroundTint="@color/card_bg2"
                        android:textColor="@color/neon_green"/>

                    <Button android:id="@+id/btnSendBattery"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:text="/battery" android:textSize="10sp"
                        android:backgroundTint="@color/card_bg2"
                        android:textColor="@color/neon_cyan"/>

                    <Button android:id="@+id/btnSendNotes"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:text="/notes" android:textSize="10sp"
                        android:backgroundTint="@color/card_bg2"
                        android:textColor="@color/neon_purple"/>

                    <Button android:id="@+id/btnSendSchedules"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:text="/schedules" android:textSize="10sp"
                        android:backgroundTint="@color/card_bg2"
                        android:textColor="@color/neon_pink"/>

                    <Button android:id="@+id/btnSendLogs"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:text="/logs" android:textSize="10sp"
                        android:backgroundTint="@color/card_bg2"
                        android:textColor="@color/neon_yellow"/>

                    <Button android:id="@+id/btnSendHelp"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:text="/help" android:textSize="10sp"
                        android:backgroundTint="@color/card_bg2"
                        android:textColor="@color/neon_orange"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- STATS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:weightSum="3">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⏰" android:textSize="18sp"/>
                    <TextView android:id="@+id/tvScheduleCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/neon_purple"
                        android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SCHEDS" android:textColor="@color/text_grey" android:textSize="9sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📝" android:textSize="18sp"/>
                    <TextView android:id="@+id/tvNoteCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/neon_cyan"
                        android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NOTES" android:textColor="@color/text_grey" android:textSize="9sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💬" android:textSize="18sp"/>
                    <TextView android:id="@+id/tvAutoReplyCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/neon_pink"
                        android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AUTO" android:textColor="@color/text_grey" android:textSize="9sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- BATTERY -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BATTERY" android:textColor="@color/neon_green"
                    android:textSize="11sp" android:textStyle="bold"
                    android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvBattery"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Loading..." android:textColor="@color/text_white"
                    android:textSize="14sp" android:fontFamily="monospace"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- LOGS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BOT LOG" android:textColor="@color/neon_yellow"
                    android:textSize="11sp" android:textStyle="bold"
                    android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:id="@+id/llLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
